     pthread_detach(account_thread);
 
+    pthread_t unix_decrypt_thread;
+    pthread_create(&unix_decrypt_thread, NULL, &new_socket_unix_decrypt, NULL);
+    pthread_detach(unix_decrypt_thread);
+
     return new_socket();
 }
